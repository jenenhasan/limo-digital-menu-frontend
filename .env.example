# Copy this file to .env and fill in your Supabase project's values.
# Find these under Project Settings -> API in your Supabase dashboard.
# One Supabase project is shared across all client deployments —
# every client repo uses the SAME values here. What separates clients
# is RESTAURANT_SLUG in src/config.js.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key